{
    "targets": {
        "debug": {
            "outFile": "build/feevest.debug.wasm",
            "textFile": "build/feevest.debug.wat",
            "sourceMap": true,
            "debug": true
        },
        "release": {
            "outFile": "build/feevest.release.wasm",
            "textFile": "build/feevest.release.wat",
            "sourceMap": false,
            "optimizeLevel": 3,
            "shrinkLevel": 2
        },
        "token-debug": {
            "outFile": "build/feetoken.debug.wasm",
            "textFile": "build/feetoken.debug.wat",
            "sourceMap": true,
            "debug": true
        }
    },
    "options": {
        "transform": "@btc-vision/opnet-transform",
        "enable": [
            "sign-extension",
            "mutable-globals",
            "nontrapping-f2i",
            "bulk-memory",
            "simd",
            "reference-types",
            "multi-value"
        ],
        "runtime": "stub",
        "converge": true,
        "memoryBase": 0,
        "initialMemory": 1,
        "optimizeLevel": 3,
        "shrinkLevel": 1,
        "noAssert": false,
        "exportStart": "start"
    }
}
