{
    "targets": {
        "debug": {
            "outFile": "build/feevest.debug.wasm",
            "textFile": "build/feevest.debug.wat",
            "sourceMap": true,
            "debug": true
        },
        "release": {
            "outFile": "build/feevest.release.wasm",
            "textFile": "build/feevest.release.wat",
            "sourceMap": false,
            "optimizeLevel": 3,
            "shrinkLevel": 2
        },
        "token-debug": {
            "outFile": "build/feetoken.debug.wasm",
            "textFile": "build/feetoken.debug.wat",
            "sourceMap": true,
            "debug": true
        }
    },
    "options": {
        "transform": "@btc-vision/opnet-transform",
        "enable": ["simd", "bulk-memory", "reference-types", "nontrapping-f2i", "sign-extension"],
        "runtime": "stub",
        "initialMemory": 1,
        "optimizeLevel": 3,
        "shrinkLevel": 1,
        "noAssert": false,
        "importMemory": false
    }
}
